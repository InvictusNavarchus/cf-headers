{
	"$schema": "node_modules/release-it/schema/release-it.json",
	"git": {
		"commitMessage": "chore(release): bump version to v${version}",
		"tagAnnotation": "Release v${version}",
		"tagName": "v${version}"
	},
	"hooks": {
		"before:github:release": "bun pm pack --destination ./release-assets/"
	},
	"github": {
		"release": true,
		"assets": ["release-assets/*.tgz"],
		"releaseName": "v${version}"
	},
	"npm": {
		"publish": false
	}
}
